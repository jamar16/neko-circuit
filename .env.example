# Copy this file to .env and fill in your own values.
# NEVER commit .env to git.

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── NextAuth ──────────────────────────────────────────────
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# ── Stripe (use TEST keys locally) ───────────────────────
STRIPE_SECRET_KEY=sk_test_your_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ── Google OAuth ──────────────────────────────────────────
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Google Analytics ──────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Lulu Direct (print fulfillment) ──────────────────────
LULU_CLIENT_ID=your_lulu_client_id
LULU_CLIENT_SECRET=your_lulu_client_secret
LULU_API_URL=https://api.lulu.com

# ── Admin ─────────────────────────────────────────────────
ADMIN_SYNC_SECRET=choose-a-strong-secret-here

# ── Abacus / hosting platform (managed — not needed locally) ──
# ABACUSAI_API_KEY=platform-managed
# WEB_APP_ID=platform-managed
# NOTIF_ID_*=platform-managed
